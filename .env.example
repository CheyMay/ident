# HTTP server
PORT=8080
PUBLIC_BASE_URL=https://integration.example.ru
DATA_DIR=./data
STORAGE_DRIVER=json
SQLITE_FILE=./data/integration.sqlite
SQLITE_MIGRATE_JSON=true

# Browser calls from the amoCRM widget need CORS.
# Defaults to https://*.amocrm.ru when empty.
CORS_ALLOWED_ORIGINS=https://*.amocrm.ru
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,X-API-Key,IDENT-Integration-Key
JOB_WORKER_ENABLED=true
JOB_WORKER_INTERVAL_MS=30000
JOB_BATCH_SIZE=10
JOB_MAX_ATTEMPTS=8
JOB_RETRY_BASE_DELAY_MS=60000

# IDENT sends this header on every request:
# IDENT-Integration-Key: <value>
IDENT_INTEGRATION_KEY=replace-with-random-secret
IDENT_REQUIRE_DOCTOR_MAPPING=false

# Optional API key for your public/internal endpoints such as POST /api/bookings.
# If empty, /api/bookings will not require X-API-Key.
SERVICE_API_KEY=

# amoCRM account. You can use either full base URL or subdomain.
AMOCRM_BASE_URL=https://example.amocrm.ru
# AMOCRM_SUBDOMAIN=example

# amoCRM OAuth.
# Long-lived tokens can use only AMOCRM_ACCESS_TOKEN and AMOCRM_LONG_LIVED_TOKEN=true.
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=
AMOCRM_ACCESS_TOKEN=
AMOCRM_REFRESH_TOKEN=
AMOCRM_LONG_LIVED_TOKEN=false
AMOCRM_TOKEN_FILE=./data/amocrm-token.json

# Lead selection for IDENT GetTickets. Leave blank to read all updated leads.
AMOCRM_PIPELINE_ID=
AMOCRM_STATUS_ID=
AMOCRM_TICKET_DATE_SOURCE=updated_at
AMOCRM_GETTICKETS_SOURCE=both
AMOCRM_DEFAULT_APPOINTMENT_MINUTES=60

# amoCRM lead custom field IDs used to build IDENT tickets.
# Plan start is the main booking field. Plan end is optional.
AMOCRM_FIELD_PLAN_START_ID=
AMOCRM_FIELD_PLAN_END_ID=
AMOCRM_FIELD_DOCTOR_ID_ID=
AMOCRM_FIELD_DOCTOR_AMO_ID_ID=
AMOCRM_FIELD_DOCTOR_NAME_ID=
AMOCRM_FIELD_COMMENT_ID=
AMOCRM_FIELD_FORM_NAME_ID=
AMOCRM_FIELD_UTM_SOURCE_ID=
AMOCRM_FIELD_UTM_MEDIUM_ID=
AMOCRM_FIELD_UTM_CAMPAIGN_ID=
AMOCRM_FIELD_UTM_TERM_ID=
AMOCRM_FIELD_UTM_CONTENT_ID=
AMOCRM_FIELD_HTTP_REFERER_ID=

# Lead creation settings for POST /api/bookings.
AMOCRM_CREATE_PIPELINE_ID=
AMOCRM_CREATE_STATUS_ID=
AMOCRM_SENT_STATUS_ID=
AMOCRM_FAILED_STATUS_ID=
AMOCRM_CREATE_TAG=IDENT
AMOCRM_ADD_NOTES=true

# amoCRM OAuth install and webhooks.
# Redirect URI in amoCRM should point to PUBLIC_BASE_URL + /oauth/amocrm/callback.
AMOCRM_WEBHOOK_EVENTS=add_lead,update_lead,status_lead

# Optional sync of IDENT schedule export into an amoCRM regular catalog.
# Create a regular list in amoCRM, put its ID here, then optionally map custom fields.
AMOCRM_SYNC_TIMETABLE_TO_CATALOG=false
AMOCRM_TIMETABLE_CATALOG_ID=
AMOCRM_TIMETABLE_SYNC_FREE_ONLY=true
AMOCRM_TIMETABLE_MAX_SYNC=100
AMOCRM_SLOT_FIELD_START_ID=
AMOCRM_SLOT_FIELD_END_ID=
AMOCRM_SLOT_FIELD_DOCTOR_ID_ID=
AMOCRM_SLOT_FIELD_DOCTOR_NAME_ID=
AMOCRM_SLOT_FIELD_BRANCH_ID_ID=
AMOCRM_SLOT_FIELD_BRANCH_NAME_ID=
AMOCRM_SLOT_FIELD_IS_BUSY_ID=
AMOCRM_SLOT_FIELD_IDENT_KEY_ID=
